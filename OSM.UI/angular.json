{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "OSM.UI": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                 "input": "src/assets",
                "output": "assets"
              }
            ],
            "styles": [
               "src/assets/css/bootstrap.min.css",
              "src/assets/plugins/icons/feather/feather.css",
              "src/assets/plugins/tabler-icons/tabler-icons.min.css",
              "src/assets/plugins/select2/css/select2.min.css",
              "src/assets/plugins/fontawesome/css/fontawesome.min.css",
              "src/assets/plugins/fontawesome/css/all.min.css",
              "src/assets/css/bootstrap-datetimepicker.min.css",
              "src/assets/plugins/bootstrap-tagsinput/bootstrap-tagsinput.css",
              "src/assets/plugins/summernote/summernote-lite.min.css",
              "src/assets/plugins/daterangepicker/daterangepicker.css",
              "src/assets/plugins/flatpickr/flatpickr.min.css",
              "src/assets/css/style.css",
              "src/styles.scss"
            ],
            "scripts": [
              "src/assets/js/bootstrap.bundle.min.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5MB",
                  "maximumError": "10MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "OSM.UI:build:production"
            },
            "development": {
              "buildTarget": "OSM.UI:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
